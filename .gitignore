# Project Specific Data
# Giữ cấu trúc thư mục bằng .gitkeep nhưng ignore các tệp dữ liệu thực tế
data/input/*
!data/input/.gitkeep
data/output/*
!data/output/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/dev/*
!data/dev/.gitkeep

# Dữ liệu tri thức y khoa lớn (cần download cục bộ khi chạy setup hoặc cache)
data/kb/*
!data/kb/override_dict.json
!data/kb/.gitkeep

# Tránh đẩy file đề bài PDF lớn lên repo
*.pdf
docs/pdf_images/

# Các thư mục code tham khảo không thuộc dự án chính
Other Source/

# Dữ liệu lớn và index FAISS
data/models/

# Các file zip
*.zip
data/*.zip

# Thư mục nháp và output phụ
scratch/
data/output_*/
data/input_*/
